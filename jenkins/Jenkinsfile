pipeline {
  agent any

  environment {
    AWS_REGION = 'us-east-1'
    ECR_REGISTRY = '713939171080.dkr.ecr.us-east-1.amazonaws.com'
    ECR_REPOSITORY = 'weather-app'
    IMAGE_NAME = 'weather-app'
    IMAGE_TAG = "${env.BUILD_NUMBER}"
    IMAGE_FULL = "${env.ECR_REGISTRY}/${env.ECR_REPOSITORY}:${env.IMAGE_TAG}"
    APP_URL = 'http://54.224.36.164:30080'
    CI = 'true'
  }

  options {
    timestamps()
    disableConcurrentBuilds()
  }

  stages {

    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Secrets Scan') {
      steps {
        sh 'gitleaks detect --source . --no-git'
      }
    }

    stage('Install Dependencies') {
      steps {
        sh 'npm ci'
      }
    }

    stage('Test') {
      steps {
        sh 'CI=true npm test -- --watchAll=false --passWithNoTests'
      }
    }

    stage('Build Frontend') {
      steps {
        withCredentials([string(credentialsId: 'openweather-api-key', variable: 'REACT_APP_OPENWEATHER_API_KEY')]) {
          sh 'npm run build'
        }
      }
    }

    stage('SAST') {
      steps {
        script {
          def scannerHome = tool(name: 'sonar-scanner', type: 'hudson.plugins.sonar.SonarRunnerInstallation')
          withSonarQubeEnv('sonarqube') {
            sh "${scannerHome}/bin/sonar-scanner"
          }
        }
      }
    }

    stage('Dependency Scan') {
      steps {
        withCredentials([string(credentialsId: 'snyk-token', variable: 'SNYK_TOKEN')]) {
          sh 'snyk auth $SNYK_TOKEN'
          sh 'snyk test --all-projects --severity-threshold=high'
          sh 'snyk monitor --all-projects'
        }
      }
    }
    stage('Container Build') {
      steps {
        withCredentials([string(credentialsId: 'openweather-api-key', variable: 'REACT_APP_OPENWEATHER_API_KEY')]) {
          sh '''
          docker build \
          --build-arg REACT_APP_OPENWEATHER_API_KEY=$REACT_APP_OPENWEATHER_API_KEY \
          -t $IMAGE_FULL .
          '''
        }
      }
    }

    stage('Container Scan') {
      steps {
        withCredentials([string(credentialsId: 'snyk-token', variable: 'SNYK_TOKEN')]) {
          sh 'snyk auth $SNYK_TOKEN'
          sh 'snyk test --docker $IMAGE_FULL --file=Dockerfile --severity-threshold=high'
        }
        sh 'trivy image --exit-code 1 --severity HIGH,CRITICAL $IMAGE_FULL'
      }
    }

    stage('Push Image to ECR') {
      steps {
        sh '''
        aws ecr get-login-password --region $AWS_REGION | \
        docker login --username AWS --password-stdin $ECR_REGISTRY

        docker push $IMAGE_FULL
        '''
      }
    }

    stage('Checkov- IaC Security Scan') {
      steps {
        sh '''
        CHECKOV_VENV="$HOME/.checkov-venv"

        if [ ! -x "$CHECKOV_VENV/bin/checkov" ]; then
          python3 -m venv "$CHECKOV_VENV"
          . "$CHECKOV_VENV/bin/activate"
          pip install --upgrade pip
          pip install checkov
        else
          . "$CHECKOV_VENV/bin/activate"
        fi

        "$CHECKOV_VENV/bin/checkov" -d k8s
        '''
      }
    }

    stage('Update Deployment file') {

      environment {
        GIT_REPO_NAME = 'weather-app-devsecops'
        GIT_EMAIL = 'Yaswanth.arumulla@gmail.com'
        GIT_USER_NAME = 'arumullayaswanth'
        YAML_FILE = 'deployment.yaml'
      }

      steps {
        dir('k8s') {

          withCredentials([string(credentialsId: 'my-git-pattoken', variable: 'git_token')]) {

            sh '''
            git config user.email "$GIT_EMAIL"
            git config user.name "$GIT_USER_NAME"

            IMAGE_DIGEST=$(aws ecr describe-images \
              --repository-name "$ECR_REPOSITORY" \
              --region "$AWS_REGION" \
              --image-ids imageTag="$BUILD_NUMBER" \
              --query 'imageDetails[0].imageDigest' \
              --output text)

            sed -i "s#image:.*#image: $ECR_REGISTRY/$ECR_REPOSITORY:$BUILD_NUMBER@$IMAGE_DIGEST#g" $YAML_FILE

            git add $YAML_FILE
            git commit -m "[skip ci] Update image to version $BUILD_NUMBER" || true
            git push https://$git_token@github.com/$GIT_USER_NAME/$GIT_REPO_NAME HEAD:master
            '''
          }
        }
      }
    }

    stage('Deploy to Kubernetes') {
      steps {
        sh '''
        kubectl apply -f k8s/namespace.yaml
        kubectl apply -f k8s/deployment.yaml
        kubectl apply -f k8s/networkpolicy.yaml
        kubectl apply -f k8s/service.yaml

        kubectl -n weather-app rollout status deployment/weather-app
        '''
      }
    }

    stage('OWASP ZAP-DAST Scan') {
      steps {
        sh '''
        docker run --rm --network host \
        ghcr.io/zaproxy/zaproxy:stable \
        zap-baseline.py -t $APP_URL -m 5 -r zap-report.html || true
        '''
      }
    }
  }

  post {
    always {
      archiveArtifacts artifacts: 'zap-report.html', allowEmptyArchive: true
      sh 'docker image prune -f'
    }
  }
}
